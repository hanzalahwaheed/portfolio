{
  "name": "hanzalahwaheed-portfolio-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "vite preview",
    "lint": "eslint",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply portfolio-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply portfolio-db --remote",
    "db:studio": "wrangler d1 execute portfolio-db --local --command \"SELECT name FROM sqlite_master WHERE type='table'\"",
    "db:introspect": "wrangler d1 execute portfolio-db --remote --command \"SELECT name FROM sqlite_master WHERE type='table'\"",
    "db:verify": "wrangler d1 execute portfolio-db --remote --command \"SELECT COUNT(*) AS count FROM Post\"",
    "db:verify:local": "wrangler d1 execute portfolio-db --local --command \"SELECT COUNT(*) AS count FROM Post\"",
    "db:export:neon": "tsx scripts/export-neon-posts-to-d1-sql.ts",
    "db:import:d1": "wrangler d1 execute portfolio-db --remote --file tmp/neon-posts-d1-import.sql"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.953.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@types/react-scroll": "^1.8.10",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.0",
    "geist": "^1.5.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.544.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-github-calendar": "^4.5.10",
    "react-markdown": "^10.1.0",
    "react-scroll": "^1.9.3",
    "react-social-icons": "^6.25.0",
    "react-textarea-autosize": "^8.5.9",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuidv7": "^1.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.1",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9",
    "postgres": "^3.4.9",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.50.0",
    "vite": "^8.0.0",
    "wrangler": "^4.94.0"
  }
}
